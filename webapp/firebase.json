{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      { "source": "/obras",        "destination": "/obras/index.html" },
      { "source": "/obras/**",     "destination": "/obras/index.html" },
      { "source": "/agenda",       "destination": "/agenda/index.html" },
      { "source": "/agenda/**",    "destination": "/agenda/index.html" },
      { "source": "/inspeccion",   "destination": "/inspeccion/index.html" },
      { "source": "/inspeccion/**","destination": "/inspeccion/index.html" },
      { "source": "**",            "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "/obras/index.html",
        "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
      },
      {
        "source": "/agenda/index.html",
        "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
      },
      {
        "source": "/index.html",
        "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
      },
      {
        "source": "/obras/assets/**",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
      },
      {
        "source": "/assets/**",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
      }
    ]
  }
}
